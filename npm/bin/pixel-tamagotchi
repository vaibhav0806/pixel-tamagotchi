#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const ext = process.platform === "win32" ? ".exe" : "";
const bin = path.join(__dirname, `pixel-tamagotchi-bin${ext}`);

if (!fs.existsSync(bin)) {
  console.error("pixel-tamagotchi binary not found. Try reinstalling:");
  console.error("  npm install -g pixel-tamagotchi");
  process.exit(1);
}

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  process.exit(e.status || 1);
}
